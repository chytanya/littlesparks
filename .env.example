# ──────────────────────────────────────────────
#  LittleSparks Prints — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── STRIPE ──────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me

# Webhook secret — get from Stripe dashboard after registering webhook
# Webhook URL: https://your-site.netlify.app/.netlify/functions/stripe-webhook
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ── STRIPE PRICE IDs ────────────────────────
# Create products in Stripe dashboard, then paste the price IDs here.
# If these are empty, the app uses fallback inline pricing (works for dev).
STRIPE_PRICE_COLORING_BOOK=price_replace_me
STRIPE_PRICE_ACTIVITY_WORKBOOK=price_replace_me
STRIPE_PRICE_HOLIDAY_PACK=price_replace_me
STRIPE_PRICE_FLASHCARDS=price_replace_me
STRIPE_PRICE_BUNDLE=price_replace_me

# ── SENDGRID ────────────────────────────────
# Get from https://app.sendgrid.com/settings/api_keys
# Also verify your sender email in SendGrid first!
SENDGRID_API_KEY=SG.replace_me
SENDGRID_FROM_EMAIL=replace-me@example.com

# ── PDF GENERATION ──────────────────────────
# Use your real local/test URL here. Do not leave placeholder/example values in Netlify.
SITE_URL=https://replace-me.local

# Optional: override the default blob store name only if needed.
PDF_BLOB_STORE=

# Optional: local-only cache directory for generated PDFs.
PDF_CACHE_DIR=

# Generate your own long random secret. Example:
# openssl rand -base64 48
DOWNLOAD_TOKEN_SECRET=replace_me_with_a_random_secret

# Coloring-book image mode:
# - template: uses only built-in printable SVG line art
# - hybrid: generate a few AI pages when OPENAI_API_KEY is set, then fill the rest with templates
# - ai: attempts AI page generation first, then falls back to templates on errors
COLORING_BOOK_IMAGE_MODE=hybrid
COLORING_BOOK_AI_PAGE_COUNT=2

# Optional: enable AI coloring-page image generation with OpenAI Images
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# ── FAUNADB (optional — for order tracking) ─
# Create a free database at https://dashboard.fauna.com
# Create a collection called "orders" and generate a server key
FAUNA_SECRET=
