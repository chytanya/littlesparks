# ──────────────────────────────────────────────
#  LittleSparks Prints — Production Environment
# ──────────────────────────────────────────────
# Copy these values into Netlify Site Settings → Environment Variables.
# Use live Stripe keys and verified email sending details in production.

# ── STRIPE (LIVE) ────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_LIVE_WEBHOOK_SECRET_HERE

# Live Stripe Price IDs
STRIPE_PRICE_COLORING_BOOK=price_live_COLORING_BOOK
STRIPE_PRICE_ACTIVITY_WORKBOOK=price_live_ACTIVITY_WORKBOOK
STRIPE_PRICE_HOLIDAY_PACK=price_live_HOLIDAY_PACK
STRIPE_PRICE_FLASHCARDS=price_live_FLASHCARDS
STRIPE_PRICE_BUNDLE=price_live_BUNDLE

# ── EMAIL ────────────────────────────────────
SENDGRID_API_KEY=SG.YOUR_PRODUCTION_KEY_HERE
SENDGRID_FROM_EMAIL=hello@littlesparks.com

# ── SITE / PDF STORAGE ──────────────────────
SITE_URL=https://littlesparks.com
PDF_BLOB_STORE=generated-pdfs
DOWNLOAD_TOKEN_SECRET=replace-with-a-long-random-secret

# ── PDF GENERATION MODE ─────────────────────
# Launch with template mode first if you want to validate payments,
# webhook delivery, attachments, and download links before enabling AI.
COLORING_BOOK_IMAGE_MODE=template
COLORING_BOOK_AI_PAGE_COUNT=2

# Optional after core launch is stable
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# ── OPTIONAL ORDER TRACKING ─────────────────
FAUNA_SECRET=
