# ──────────────────────────────────────────────
#  LittleSparks Prints — Production Environment
# ──────────────────────────────────────────────
# Copy these values into Netlify Site Settings → Environment Variables.
# Use live Stripe keys and verified email sending details in production.

# ── STRIPE (LIVE) ────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Live Stripe Price IDs
STRIPE_PRICE_COLORING_BOOK=price_live_replace_me
STRIPE_PRICE_ACTIVITY_WORKBOOK=price_live_replace_me
STRIPE_PRICE_HOLIDAY_PACK=price_live_replace_me
STRIPE_PRICE_FLASHCARDS=price_live_replace_me
STRIPE_PRICE_BUNDLE=price_live_replace_me

# ── EMAIL ────────────────────────────────────
SENDGRID_API_KEY=SG.replace_me
SENDGRID_FROM_EMAIL=replace-me@example.com

# ── SITE / PDF STORAGE ──────────────────────
SITE_URL=https://replace-me.example.com

# Optional: override only if you do not want the code default store name.
PDF_BLOB_STORE=

# Generate your own long random secret. Example:
# openssl rand -base64 48
DOWNLOAD_TOKEN_SECRET=replace_me_with_a_random_secret

# ── PDF GENERATION MODE ─────────────────────
# Launch with template mode first if you want to validate payments,
# webhook delivery, attachments, and download links before enabling AI.
COLORING_BOOK_IMAGE_MODE=template
COLORING_BOOK_AI_PAGE_COUNT=2

# Optional after core launch is stable
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# ── OPTIONAL ORDER TRACKING ─────────────────
FAUNA_SECRET=
