{
  "name": "littlesparks-prints",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:vite": "vite --host 127.0.0.1 --port 3000 --strictPort",
    "dev:netlify": "concurrently -k -n vite,functions -c green,blue \"npm:dev:vite\" \"netlify functions:serve\"",
